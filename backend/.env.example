# Flask 环境变量示例
# 复制此文件为 .env 并根据需要修改

FLASK_ENV=development
FLASK_DEBUG=1

# 数据库配置
# ✅ 本地开发 (默认): SQLite - 自动创建 piano_app.db
# DATABASE_URL=sqlite:///piano_app.db

# 📦 生产环境: MySQL
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/piano_app

# JWT 配置 (⚠️ 必须在生产环境修改)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# 服务器配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
